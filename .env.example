# GoHighLevel API (boat seats custom value; subscribe uses inbound webhook in code)
GHL_API_KEY=
GHL_LOCATION_ID=

# Optional: override website email signup webhook (defaults to LeadConnector hook in code)
# SUBSCRIBE_WEBHOOK_URL=

# GoHighLevel inbound webhook URL for free Book Party registration (step 1 funnel).
# Create a workflow that sends the confirmation email for non-VIP registrants.
GHL_BOOK_PARTY_FREE_REGISTRATION_WEBHOOK_URL=

# GHL custom value ID that stores remaining boat seats (integer).
# Create via API (needs Private Integration scope locations/customValues.write):
#   npm run ghl:create-boat-seats-custom-value
# Or manually: Settings → Business Info → Custom Values.
GHL_CUSTOM_VALUE_BOAT_SEATS_ID=

# Stripe — HTNS Book Party (/htns-book-party)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Test-mode secret from Dashboard → Developers → Webhooks (test) or from `npm run stripe:listen` (HTNS sandbox CLI project `htns`).
STRIPE_WEBHOOK_SECRET=

# VIP checkout uses boat + hotel REGULAR price only (no early-bird tier on site).
STRIPE_PRICE_BOAT_AND_HOTEL_REGULAR=

# Optional legacy fallbacks if the key above is unset.
STRIPE_PRICE_BOOK_PARTY_REGULAR=

# Optional: early-boat/hotel price ID (legacy webhook resolution only; not used for checkout).
STRIPE_PRICE_BOAT_AND_HOTEL_EARLY=
STRIPE_PRICE_BOOK_PARTY_EARLY=

# Optional: hotel-only price IDs (legacy webhook resolution only; not sold on site).
STRIPE_PRICE_HOTEL_ONLY_REGULAR=
STRIPE_PRICE_HOTEL_ONLY_EARLY=

# Vercel Web Analytics: enable in Vercel project → Analytics. @vercel/analytics in layout (no env required on Vercel).
